# Your relay's public domain name (must have DNS pointing to this server)
RELAY_DOMAIN=relay.example.com

# Your server's public IP address
PUBLIC_IP=1.2.3.4

# TURN server shared secret (generate with: openssl rand -hex 32)
TURN_SECRET=change-me-generate-with-openssl-rand-hex-32

# Email for Let's Encrypt certificate notifications
CERTBOT_EMAIL=you@example.com
